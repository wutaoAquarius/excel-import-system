{
  "name": "excel-import-system",
  "version": "1.0.0",
  "description": "万能导入——多模板自动导入下单系统",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns='__tests__/unit'",
    "test:integration": "jest --testPathPatterns='__tests__/integration'",
    "db:push": "prisma db push --skip-generate --skip-validate",
    "db:push:force": "prisma db push --skip-generate --skip-validate --force-reset",
    "db:seed": "node --require ts-node/register prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tanstack/react-table": "^8.10.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@vercel/postgres": "^0.7.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.3.0",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "string-similarity": "^4.0.4",
    "xlsx": "^0.18.5",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^30.3.0",
    "postcss": "^8.4.32",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
